#!/usr/bin/env bash
# ABOUTME: Test stand-in for the codex CLI. Reads the workstream marker embedded in the prompt and
# ABOUTME: simulates pass / fail-once / hang / no-op / conflicting workstreams plus merge resolution.
set -u

DIR=.
PROMPT=""
OFILE=""
MODE=exec
args=("$@")
i=0
while [ $i -lt ${#args[@]} ]; do
  a="${args[$i]}"
  case "$a" in
    -C) i=$((i+1)); DIR="${args[$i]}" ;;
    -o) i=$((i+1)); OFILE="${args[$i]}" ;;
    -s|-m|-c|-p) i=$((i+1)) ;;
    review) MODE=review ;;
    exec|--ephemeral|--skip-git-repo-check|--json|--uncommitted) ;;
    --base) i=$((i+1)) ;;
    *) PROMPT="$a" ;;
  esac
  i=$((i+1))
done

log() { echo "$1 dir=$DIR" >> "${STUB_DIR:?}/invocations.log"; }
bump() { echo x >> "${STUB_DIR:?}/calls-$1"; }

if [ "$MODE" = "review" ]; then
  bump REVIEW; log REVIEW
  [ -n "$OFILE" ] && echo "stub review: no findings" > "$OFILE"
  echo "stub review done"
  exit 0
fi

case "$PROMPT" in
  *"merge conflict"*)
    bump MERGE-RESOLVE; log MERGE-RESOLVE
    echo "ok-merged" > "$DIR/c.txt"
    git -C "$DIR" add c.txt
    ;;
  *WS-OK*)
    bump WS-OK; log WS-OK
    echo "ok-ws1" > "$DIR/a.txt"
    ;;
  *WS-FAILONCE*)
    bump WS-FAILONCE; log WS-FAILONCE
    case "$PROMPT" in
      *"PREVIOUS ATTEMPT FAILED"*) echo "ok-ws2" > "$DIR/b.txt" ;;
      *) echo "bad" > "$DIR/b.txt" ;;
    esac
    ;;
  *WS-HANG*)
    bump WS-HANG; log WS-HANG
    sleep 30
    ;;
  *WS-NOOP*)
    bump WS-NOOP; log WS-NOOP
    ;;
  *WS-C1*)
    bump WS-C1; log WS-C1
    echo "ok-ws5" > "$DIR/c.txt"
    ;;
  *WS-C2*)
    bump WS-C2; log WS-C2
    echo "ok-ws6" > "$DIR/c.txt"
    ;;
  *WS-D*)
    bump WS-D; log WS-D
    echo "ok-d" > "$DIR/d.txt"
    ;;
  *WS-E*)
    bump WS-E; log WS-E
    echo "ok-e" > "$DIR/e.txt"
    ;;
  *)
    bump UNKNOWN; log "UNKNOWN prompt=$PROMPT"
    exit 1
    ;;
esac
echo "stub codex done"
exit 0
